{
  "name": "gare-lotti-milanesi",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "deploy": "npm run deploy:cloudflare",
    "deploy:cloudflare": "node scripts/deploy-cloudflare.mjs production",
    "deploy:doctor": "node scripts/deploy-doctor.mjs",
    "deploy:preview": "node scripts/deploy-cloudflare.mjs preview",
    "preview": "vite preview --host 127.0.0.1",
    "prepublish:check": "git diff --check && npm run validate:data && npm test && npm run build && npm run smoke",
    "release": "node scripts/release.mjs",
    "release:dry-run": "node scripts/release.mjs --dry-run",
    "benchmark:optimization": "vitest run --config vitest.benchmark.config.ts",
    "smoke": "node scripts/smoke.mjs",
    "test": "vitest run",
    "validate:data": "vitest run src/data/tender.validation.test.ts src/data/demo-data.validation.test.ts",
    "validate:demo": "vitest run src/data/demo-data.validation.test.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^1.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.57.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.93.0"
  },
  "overrides": {
    "ws": "8.20.1"
  }
}
